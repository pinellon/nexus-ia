{
  "model": {
    "hidden_size": 256,
    "num_layers": 8,
    "num_heads": 8,
    "vocab_size": 32000,
    "max_seq_len": 256
  },
  "training": {
    "batch_size": 16,
    "micro_batch_size": 4,
    "gradient_accumulation_steps": 4,
    "epochs": 200,
    "learning_rate": 5e-4,
    "checkpoint_interval": 500,
    "mixed_precision": true,
    "use_cpu_fallback": true,
    "early_stop": {
      "window": 20,
      "threshold": 0.5
    }
  },
  "paths": {
    "raw_data": "data/raw",
    "clean_data": "data/clean",
    "token_dir": "data/tokens",
    "model_dir": "model",
    "memory_file": "memory/memory.db",
    "log_dir": "logs",
    "project_root": "projects",
    "cache_dir": "cache"
  },
  "safety": {
    "dangerous_commands": ["del", "rm -rf", "shutdown", "format", "reg delete"],
    "confirm_prompt": true,
    "allowed_project_path": "C:/nexus ai/NexusAI/projects"
  },
  "translation": {
    "api_url": "https://libretranslate.de/translate",
    "supported_languages": ["en", "pt"]
  }
}
