{
  "model": {
    "hidden_size": 256,
    "num_layers": 4,
    "num_heads": 4,
    "dim_ff": 1024,
    "vocab_size": 12000,
    "max_seq_len": 512
  },
  "training": {
    "batch_size": 16,
    "micro_batch_size": 2,
    "gradient_accumulation_steps": 8,
    "epochs": 999999,
    "learning_rate": 0.00012,
    "checkpoint_interval": 500,
    "mixed_precision": true,
    "use_cpu_fallback": true,
    "early_stop": {
      "window": 0,
      "threshold": 0.0
    }
  },
  "paths": {
    "raw_data": "data/raw",
    "clean_data": "data/instruction_clean",
    "token_dir": "data/tokens_instruct_fullstack",
    "model_dir": "model_instruct_fullstack",
    "memory_file": "memory/memory.db",
    "log_dir": "logs",
    "project_root": "projects"
  },
  "safety": {
    "dangerous_commands": ["del", "rm -rf", "shutdown", "format", "reg delete"],
    "confirm_prompt": true,
    "allowed_project_path": "C:/nexus ai/NexusAI/projects"
  }
}
