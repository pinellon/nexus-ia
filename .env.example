PORT=4000

# ── Nexus AI Router ────────────────────────────────────────────────────────
NEXUS_AI_PROVIDER=auto
NEXUS_AI_MODE=balanced
NEXUS_PREMIUM_PROVIDER=anthropic
NEXUS_ALLOW_PREMIUM_FALLBACK=true
NEXUS_REQUIRE_PREMIUM_CONFIRMATION=false

# ── Anthropic / Claude ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── OpenAI ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1

# ── Google Gemini ──────────────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro

# ── Groq ───────────────────────────────────────────────────────────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ── OpenRouter ─────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4

# ── Ollama (local) ─────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b

# ── Agentes multi-provider ─────────────────────────────────────────────────
ENABLE_CLAUDE=true
ENABLE_CODEX=true
ENABLE_BLACKBOX=false
ENABLE_ANTYGRAVIT=true
ENABLE_MOCK=true

# ── Integrações externas ───────────────────────────────────────────────────
GITHUB_TOKEN=
BLACKBOX_API_KEY=
BLACKBOX_API_URL=
NEXUS_MONTHLY_API_BUDGET_BRL=20
